# Eden AI API key (required for voice agent: LLM + STT + TTS)
EDENAI_API_KEY=your-eden-ai-api-key

# Eden AI model selectors. Format: "<provider>/<model>".
EDENAI_MODEL=openai/gpt-4.1-mini
EDENAI_STT_PROVIDER=audio/speech_to_text_async/deepgram/nova-3
EDENAI_TTS_PROVIDER=audio/tts/elevenlabs/eleven_flash_v2_5

# LiveKit credentials (auto-generated for Railway, set manually for local dev)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
